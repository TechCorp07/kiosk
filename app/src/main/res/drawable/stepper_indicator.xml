<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active state -->
    <item android:state_activated="true">
        <shape android:shape="oval">
            <solid android:color="@color/zimpudo_primary" />
            <size
                android:width="32dp"
                android:height="32dp" />
        </shape>
    </item>
    <!-- Inactive state -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/background_primary" />
            <stroke
                android:width="2dp"
                android:color="@color/text_hint" />
            <size
                android:width="32dp"
                android:height="32dp" />
        </shape>
    </item>
</selector>