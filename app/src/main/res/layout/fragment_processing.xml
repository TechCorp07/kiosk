<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tvProcessingTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:text="Processing Your Package"
                android:textColor="@color/text_primary"
                android:textSize="36sp"
                android:textStyle="bold" />

            <!-- Locker Code Display Card (Visible when locker opens) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLockerAssigned"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/corner_radius_md"
                app:cardElevation="@dimen/elevation_md"
                app:cardBackgroundColor="@color/success_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Locker Opened"
                        android:textColor="@color/success_text"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvLockerNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="--"
                        android:textColor="@color/success_dark"
                        android:textSize="120sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="Please place your package inside and securely close the door."
                        android:textColor="@color/success_text"
                        android:textSize="20sp"
                        android:textAlignment="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Steps Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_gray"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <!-- Step 1: Payment Verification -->
                <LinearLayout
                    android:id="@+id/stepPayment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/spacing_sm">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp">
                        <ProgressBar
                            android:id="@+id/progressPayment"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminateTint="@color/zimpudo_primary" />
                        <ImageView
                            android:id="@+id/ivPaymentDone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/success"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvPaymentText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="Waiting for payment approval..."
                        android:textColor="@color/text_primary"
                        android:textSize="24sp" />
                </LinearLayout>

                <!-- Step 2: Receipt Printing -->
                <LinearLayout
                    android:id="@+id/stepReceipt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/spacing_sm"
                    android:alpha="0.4">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp">
                        <ImageView
                            android:id="@+id/ivReceiptIcon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:src="@drawable/ic_receipt"
                            app:tint="@color/text_secondary" />
                        <ProgressBar
                            android:id="@+id/progressReceipt"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone"
                            android:indeterminateTint="@color/zimpudo_primary" />
                        <ImageView
                            android:id="@+id/ivReceiptDone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/success"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvReceiptText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="Printing your receipt"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp" />
                </LinearLayout>

                <!-- Step 3: Waybill Label Printing -->
                <LinearLayout
                    android:id="@+id/stepLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/spacing_sm"
                    android:alpha="0.4">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp">
                        <ImageView
                            android:id="@+id/ivLabelIcon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:src="@drawable/ic_code"
                            app:tint="@color/text_secondary" />
                        <ProgressBar
                            android:id="@+id/progressLabel"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone"
                            android:indeterminateTint="@color/zimpudo_primary" />
                        <ImageView
                            android:id="@+id/ivLabelDone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/success"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvLabelText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="Printing waybill label"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp" />
                </LinearLayout>

                <!-- Step 4: Locker Opening & Door Monitoring -->
                <LinearLayout
                    android:id="@+id/stepLocker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/spacing_sm"
                    android:alpha="0.4">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp">
                        <ImageView
                            android:id="@+id/ivLockerIcon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:src="@drawable/ic_locker_open"
                            app:tint="@color/text_secondary" />
                        <ProgressBar
                            android:id="@+id/progressLocker"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone"
                            android:indeterminateTint="@color/zimpudo_primary" />
                        <ImageView
                            android:id="@+id/ivLockerDone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/success"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvLockerText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="Opening locker"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvThankYouCountdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="Thank you! Returning to main menu in 5s..."
                android:textAlignment="center"
                android:textColor="@color/text_secondary"
                android:textSize="24sp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" /> <!-- Spacer for bottom padding -->

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
