<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_primary"
    android:orientation="vertical">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_xl">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="250dp"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="@color/white" />

        <!-- ZIMPUDO Logo — 10x wide, 1.5x tall, centred -->
        <ImageView
            android:layout_width="500dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/zimpudo_logo"
            android:contentDescription="@string/app_name"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Welcome Message -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WELCOME | MAUYA | SIYAKWAMUKELA"
            android:textColor="@color/text_white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2" />
    </LinearLayout>

    <!-- Language Selection Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_white_rounded_top"
        android:orientation="vertical"
        android:gravity="bottom"
        android:padding="@dimen/spacing_xl">

        <!-- Title -->

        <!-- Subtitle -->

        <!-- Language List — grows to fill available space -->
        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:text="@string/select_language" />

        <!-- Continue Button — big kiosk button, centred, ~65% width -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLanguages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:clipToPadding="false"
            android:overScrollMode="never" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnContinue"
                style="@style/Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:layout_marginStart="100dp"
                android:layout_marginEnd="100dp"
                android:drawableEnd="@drawable/ic_arrow_forward"
                android:drawablePadding="@dimen/spacing_md"
                android:minWidth="0dp"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:text="@string/continue_button"
                android:textSize="52sp" />

        </FrameLayout>

    </LinearLayout>

</LinearLayout>