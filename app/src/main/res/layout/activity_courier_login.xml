<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_primary"
    android:orientation="vertical">

    <!-- Green header — 2/7 of screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_xl">

        <!-- Back button -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="start"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/white"
                android:contentDescription="@string/auto_rem_back" />
        </FrameLayout>

        <!-- Logo -->
        <ImageView
            android:layout_width="500dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/zimpudo_logo"
            android:contentDescription="@string/app_name" />

    </LinearLayout>

    <!-- White panel — 5/7 of screen -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:background="@drawable/bg_white_rounded_top"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl"
            android:gravity="center_horizontal">

            <!-- Courier Icon -->
            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="@dimen/spacing_md"
                android:src="@drawable/ic_courier"
                android:tint="@color/zimpudo_primary"
                android:contentDescription="@string/auto_rem_courier_icon" />

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_courier"
                android:textColor="@color/text_primary"
                android:textSize="78sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="@dimen/spacing_xl" />

            <!-- Mobile Number — 60dp margins -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilMobile"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="60dp"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:hint="@string/auto_mobile_number"
                app:startIconDrawable="@drawable/ic_phone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMobile"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:inputType="phone"
                    android:maxLength="15"
                    android:hint="@string/auto_2637xxxxxxxx"
                    android:textColorHint="@color/text_hint"
                    android:textSize="32sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- PIN — 60dp margins -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPin"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="60dp"
                android:layout_marginBottom="@dimen/spacing_xl"
                android:hint="@string/auto_6_digit_pin"
                app:endIconMode="password_toggle"
                app:startIconDrawable="@drawable/ic_pin_security">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPin"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:inputType="numberPassword"
                    android:maxLength="6"
                    android:textSize="32sp"
                    android:letterSpacing="0.3" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/spacing_md"
                android:visibility="gone" />

            <!-- Login Button — centred, not edge-to-edge -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="100dp"
                    android:layout_marginEnd="100dp"
                    android:text="@string/auto_sign_in"
                    android:textSize="52sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/zimpudo_primary"
                    android:textColor="@color/white" />

            </FrameLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
