<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- Header with logout -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@drawable/zimpudo_logo"
                    android:contentDescription="@string/app_name" />

                <ImageButton
                    android:id="@+id/btnLogout"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_logout"
                    android:contentDescription="@string/auto_rem_logout"
                    app:tint="@color/white" />
            </FrameLayout>

            <!-- Welcome message -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:gravity="center"
                android:text="@string/auto_welcome_courier"
                android:textColor="@color/text_white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/auto_ready_to_make_deliveries"
                android:textColor="@color/text_white"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- Main Actions Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_white_rounded_top"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Accept Orders Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAcceptOrders"
                android:layout_width="match_parent"
                android:layout_height="@dimen/kiosk_card_height"
                android:layout_marginBottom="@dimen/spacing_md"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/elevation_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/kiosk_icon_size"
                        android:layout_height="@dimen/kiosk_icon_size"
                        android:layout_gravity="center"
                        android:layout_marginEnd="@dimen/spacing_lg"
                        android:src="@drawable/ic_add_circle"
                        app:tint="@color/zimpudo_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvAcceptOrders"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:text="Accept Orders"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAcceptDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Browse and accept available delivery orders"
                            android:textColor="@color/text_secondary"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/text_hint" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pickup Packages Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPickupPackages"
                android:layout_width="match_parent"
                android:layout_height="@dimen/kiosk_card_height"
                android:layout_marginBottom="@dimen/spacing_md"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/elevation_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/kiosk_icon_size"
                        android:layout_height="@dimen/kiosk_icon_size"
                        android:layout_gravity="center"
                        android:layout_marginEnd="@dimen/spacing_lg"
                        android:src="@drawable/ic_pickup"
                        app:tint="@color/zimpudo_primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <TextView
                                android:id="@+id/tvPickupPackages"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_pickup_packages"
                                android:textColor="@color/text_primary"
                                android:textSize="26sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvCollectBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:background="@color/error"
                                android:textColor="@color/white"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:visibility="gone" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvPickupDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_collect_packages_from_this_kio"
                            android:textColor="@color/text_secondary"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/text_hint" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Deliver Packages Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDeliverPackages"
                android:layout_width="match_parent"
                android:layout_height="@dimen/kiosk_card_height"
                android:layout_marginBottom="@dimen/spacing_md"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/elevation_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/kiosk_icon_size"
                        android:layout_height="@dimen/kiosk_icon_size"
                        android:layout_gravity="center"
                        android:layout_marginEnd="@dimen/spacing_lg"
                        android:src="@drawable/ic_deliver"
                        app:tint="@color/success" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDeliverPackages"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:text="@string/auto_deliver_packages"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDeliverDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_drop_off_packages_at_this_kios"
                            android:textColor="@color/text_secondary"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/text_hint" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- View Route Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewRoute"
                android:layout_width="match_parent"
                android:layout_height="@dimen/kiosk_card_height"
                android:layout_marginBottom="@dimen/spacing_md"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/elevation_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/kiosk_icon_size"
                        android:layout_height="@dimen/kiosk_icon_size"
                        android:layout_gravity="center"
                        android:layout_marginEnd="@dimen/spacing_lg"
                        android:src="@drawable/ic_route"
                        app:tint="@color/info" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvViewRoute"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:text="@string/auto_view_my_route"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvRouteDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_see_your_assigned_delivery_rou"
                            android:textColor="@color/text_secondary"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/text_hint" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Update Status Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardUpdateStatus"
                android:layout_width="match_parent"
                android:layout_height="@dimen/kiosk_card_height"
                android:layout_marginBottom="@dimen/spacing_md"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/elevation_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/kiosk_icon_size"
                        android:layout_height="@dimen/kiosk_icon_size"
                        android:layout_gravity="center"
                        android:layout_marginEnd="@dimen/spacing_lg"
                        android:src="@drawable/ic_update"
                        app:tint="@color/warning" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvUpdateStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:text="@string/auto_update_status"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvStatusDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_update_delivery_status_and_add"
                            android:textColor="@color/text_secondary"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/text_hint" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Courier Profile Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCourierProfile"
                android:layout_width="match_parent"
                android:layout_height="@dimen/kiosk_card_height"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/elevation_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/kiosk_icon_size"
                        android:layout_height="@dimen/kiosk_icon_size"
                        android:layout_gravity="center"
                        android:layout_marginEnd="@dimen/spacing_lg"
                        android:src="@drawable/ic_person"
                        app:tint="@color/zimpudo_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCourierProfile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:text="@string/auto_my_profile"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvProfileDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_manage_your_courier_profile_an"
                            android:textColor="@color/text_secondary"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/text_hint" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>