<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_primary"
    android:orientation="vertical">

    <!-- Green header — 2/7 of screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_xl">

        <!-- Back button -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="@string/auto_rem_back"
                app:tint="@color/white" />
        </FrameLayout>

        <!-- Logo -->
        <ImageView
            android:layout_width="500dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/zimpudo_logo"
            android:contentDescription="@string/app_name" />

    </LinearLayout>

    <!-- White panel — 5/7 of screen -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:background="@drawable/bg_white_rounded_top"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl"
            android:gravity="center_horizontal">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_collect_your_package"
                android:textColor="@color/text_primary"
                android:textSize="60sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="@dimen/spacing_xl" />

            <!-- Tracking Number Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTrackingNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="60dp"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:hint="@string/auto_tracking_number"
                app:startIconDrawable="@drawable/ic_pickup"
                app:startIconTint="@color/zimpudo_primary"
                app:hintTextColor="@color/zimpudo_primary"
                app:boxStrokeColor="@color/zimpudo_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTrackingNumber"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:hint="@string/auto_e_g_zp_20260328_xxxx"
                    android:textColorHint="@color/text_hint"
                    android:inputType="textCapCharacters"
                    android:textSize="32sp"
                    android:letterSpacing="0.10"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- OTP / Collection Code Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCollectionCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="60dp"
                android:layout_marginBottom="@dimen/spacing_xl"
                android:hint="@string/auto_collection_otp"
                app:startIconDrawable="@drawable/ic_key"
                app:startIconTint="@color/zimpudo_primary"
                app:endIconMode="password_toggle"
                app:hintTextColor="@color/zimpudo_primary"
                app:boxStrokeColor="@color/zimpudo_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCollectionCode"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:hint="@string/auto_6_digit_code_from_sms"
                    android:textColorHint="@color/text_hint"
                    android:inputType="number"
                    android:textSize="32sp"
                    android:letterSpacing="0.25"
                    android:gravity="center_vertical"
                    android:maxLines="1"
                    android:maxLength="6" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Open Locker Button — centred, not edge-to-edge -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenLocker"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="100dp"
                    android:layout_marginEnd="100dp"
                    android:text="@string/auto_open_locker"
                    android:textSize="52sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/zimpudo_primary" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="@color/white" />

            </FrameLayout>

            <!-- Status message -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_card"
                android:gravity="center"
                android:padding="@dimen/spacing_md"
                android:textColor="@color/text_primary"
                android:textSize="36sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
