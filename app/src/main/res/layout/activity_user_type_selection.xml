<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_primary"
    android:orientation="vertical">

    <!-- Green header — 2/7 of screen -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/spacing_xl">

            <!-- Logo — centred -->
            <ImageView
                android:layout_width="1000dp"
                android:layout_height="400dp"
                android:layout_gravity="center_horizontal"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/zimpudo_logo"
                android:contentDescription="@string/app_name" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="start|top"
            android:layout_margin="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:scaleType="fitCenter"
            android:tint="@color/white"
            android:contentDescription="@string/auto_rem_back" />
    </FrameLayout>

    <!-- White panel — 5/7 of screen, cards fill it completely -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:background="@drawable/bg_white_rounded_top"
        android:orientation="vertical"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md">

        <!-- Customer Receive Card — fills 1/3 of white area -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCustomerReceive"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:cardElevation="@dimen/elevation_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:src="@drawable/ic_customer"
                    android:contentDescription="@string/auto_rem_customer_receive_icon"
                    app:tint="@color/zimpudo_primary" />

                <TextView
                    android:id="@+id/tvCustomerReceiveTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/user_type_customer_receive"
                    android:textColor="@color/text_primary"
                    android:textSize="50sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCustomerReceiveDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/user_type_customer_receive_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="36sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Customer Send Card — fills 1/3 of white area -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCustomerSend"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:cardElevation="@dimen/elevation_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:src="@drawable/ic_customer"
                    android:contentDescription="@string/auto_rem_customer_send_icon"
                    app:tint="@color/zimpudo_primary" />

                <TextView
                    android:id="@+id/tvCustomerSendTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/user_type_customer_send"
                    android:textColor="@color/text_primary"
                    android:textSize="50sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCustomerSendDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/user_type_customer_send_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="36sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Courier Card — fills 1/3 of white area -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCourier"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:cardElevation="@dimen/elevation_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:src="@drawable/ic_courier"
                    android:contentDescription="@string/auto_rem_courier_icon"
                    app:tint="@color/zimpudo_primary" />

                <TextView
                    android:id="@+id/tvCourierTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/user_type_courier"
                    android:textColor="@color/text_primary"
                    android:textSize="50sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCourierDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/user_type_courier_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="36sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>