<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_lg">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="@string/back"
                app:tint="@color/white" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/zimpudo_logo"
                android:contentDescription="@string/app_name" />
        </FrameLayout>

        <!-- Content Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_white_rounded_top"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl">

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                style="@style/Text.Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/creating_account"
                android:gravity="center" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                style="@style/Text.Subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xl"
                android:text="@string/kyc_subtitle"
                android:gravity="center"
                android:visibility="gone" />

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:indeterminateTint="@color/zimpudo_primary" />

            <!-- Loading Message -->
            <TextView
                android:id="@+id/tvLoadingMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:textColor="@color/zimpudo_primary"
                android:textSize="22sp"
                android:text="@string/creating_account"
                android:gravity="center" />

            <!-- Error State Container -->
            <LinearLayout
                android:id="@+id/llErrorState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvErrorMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#E53935"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_lg" />

                <Button
                    android:id="@+id/btnRetry"
                    style="@style/Button.Primary"
                    android:layout_width="match_parent"
                    android:text="Retry" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>