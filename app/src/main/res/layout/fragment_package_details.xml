<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomButtons"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:text="@string/auto_enter_package_details"
                android:textColor="@color/text_primary"
                android:textSize="36sp"
                android:textStyle="bold" />

            <!-- Dimensions Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/auto_package_dimensions_in_mm"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Length -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilLength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:boxStrokeColor="@color/zimpudo_primary"
                app:hintTextColor="@color/zimpudo_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLength"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:hint="@string/auto_length_mm"
                    android:inputType="number"
                    android:textSize="22sp"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Width -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilWidth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:boxStrokeColor="@color/zimpudo_primary"
                app:hintTextColor="@color/zimpudo_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWidth"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:hint="@string/auto_width_mm"
                    android:inputType="number"
                    android:textSize="22sp"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Height -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilHeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:boxStrokeColor="@color/zimpudo_primary"
                app:hintTextColor="@color/zimpudo_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHeight"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:hint="@string/auto_height_mm"
                    android:inputType="number"
                    android:textSize="22sp"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Calculated Size Display -->
            <TextView
                android:id="@+id/tvCalculatedSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:background="@color/success_light"
                android:padding="@dimen/spacing_md"
                android:text="@string/auto_calculated_size_medium"
                android:textColor="@color/success"
                android:textSize="24sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Package Contents Selection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_package_contents"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <Spinner
                android:id="@+id/spinnerContents"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_md"
                android:background="@drawable/bg_input_field" />

            <!-- Optional finer details -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilContents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:boxStrokeColor="@color/zimpudo_primary"
                app:hintTextColor="@color/zimpudo_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etContents"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:hint="@string/auto_additional_details_optional"
                    android:inputType="textCapSentences"
                    android:textSize="20sp"
                    android:maxLines="2" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Currency Selection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_currency"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <Spinner
                android:id="@+id/spinnerCurrency"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_md"
                android:background="@drawable/bg_input_field" />

            <!-- Package Class Selection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_package_class"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <Spinner
                android:id="@+id/spinnerPackageClass"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_md"
                android:background="@drawable/bg_input_field" />

            <!-- Receiver Mode Selection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_delivery_mode_recipient"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <Spinner
                android:id="@+id/spinnerReceiverMode"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_md"
                android:background="@drawable/bg_input_field" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnBack"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:layout_weight="1"
            android:text="@string/auto_back"
            android:textSize="24sp"
            android:textColor="@color/zimpudo_primary"
            app:strokeColor="@color/zimpudo_primary" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:backgroundTint="@color/zimpudo_primary"
            android:text="@string/auto_create_order"
            android:textSize="24sp"
            android:textColor="@color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>