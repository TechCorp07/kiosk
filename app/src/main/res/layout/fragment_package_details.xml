<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomButtons"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:text="Enter Package Details"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- Dimensions Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="Package Dimensions (in meters)"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- Length -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilLength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:boxStrokeColor="@color/zimpudo_primary"
                app:hintTextColor="@color/zimpudo_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLength"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Length (m)"
                    android:inputType="numberDecimal"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Width -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilWidth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:boxStrokeColor="@color/zimpudo_primary"
                app:hintTextColor="@color/zimpudo_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWidth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Width (m)"
                    android:inputType="numberDecimal"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Height -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilHeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:boxStrokeColor="@color/zimpudo_primary"
                app:hintTextColor="@color/zimpudo_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Height (m)"
                    android:inputType="numberDecimal"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Calculated Size Display -->
            <TextView
                android:id="@+id/tvCalculatedSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:background="@color/success_light"
                android:padding="@dimen/spacing_md"
                android:text="Calculated Size: Medium"
                android:textColor="@color/success"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Contents -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilContents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:boxStrokeColor="@color/zimpudo_primary"
                app:hintTextColor="@color/zimpudo_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etContents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Package Contents"
                    android:inputType="textCapSentences"
                    android:maxLines="3" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Currency Selection -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="Payment Currency"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerCurrency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:minHeight="48dp"
                android:padding="@dimen/spacing_md" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnBack"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:layout_weight="1"
            android:text="Back"
            android:textColor="@color/zimpudo_primary"
            app:strokeColor="@color/zimpudo_primary" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:backgroundTint="@color/zimpudo_primary"
            android:text="Create Order"
            android:textColor="@color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>