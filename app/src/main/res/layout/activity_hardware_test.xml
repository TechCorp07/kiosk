<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#f5f5f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#E8F5E8"
            android:layout_marginBottom="16dp"
            android:padding="8dp">
            
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="@string/auto_rem_back"
                android:tint="#2E7D32" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/auto_pudo_kiosk_hardware_test_cente"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:gravity="center"
                android:padding="16dp" />
        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- ===== STM32 LOCKER CONTROLLER (RS485) ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="3dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_stm32l412_locker_controller"
                android:textStyle="bold"
                android:textSize="26sp"
                android:textColor="#1976D2"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_rs485_communication_with_up_to"
                android:textSize="15sp"
                android:textColor="#666666"
                android:layout_marginBottom="12dp" />

            <!-- Connection Status -->
            <TextView
                android:id="@+id/tvLockerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_not_connected"
                android:textSize="16sp"
                android:padding="10dp"
                android:background="#E8F5E8"
                android:layout_marginBottom="10dp"
                android:textColor="#2E7D32" />

            <!-- Connect + Test Comm -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnConnectLocker"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_connect"
                    android:background="#1976D2"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnTestCommunication"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_test_comm"
                    android:background="#388E3C"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:textSize="15sp"
                    android:enabled="false" />
            </LinearLayout>

            <!-- Board + Lock Selection -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_board"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:layout_marginEnd="6dp" />

                <Spinner
                    android:id="@+id/spinnerBoardNumber"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_lock"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:layout_marginEnd="6dp" />

                <Spinner
                    android:id="@+id/spinnerLockNumber"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btnUnlockSingle"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_unlock"
                    android:background="#FF9800"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"
                    android:textSize="14sp"
                    android:enabled="false" />

                <Button
                    android:id="@+id/btnCheckStatus"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_status"
                    android:background="#607D8B"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:textSize="14sp"
                    android:enabled="false" />
            </LinearLayout>

            <!-- Batch Operations -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/btnCheckAllStatus"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_check_all"
                    android:background="#5E35B1"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"
                    android:textSize="14sp"
                    android:enabled="false" />

                <Button
                    android:id="@+id/btnEmergencyUnlock"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_emergency"
                    android:background="#D32F2F"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:textSize="14sp"
                    android:enabled="false" />

                <Button
                    android:id="@+id/btnStartListening"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_listen"
                    android:background="#607D8B"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:textSize="14sp" />
            </LinearLayout>



            <!-- Log Header -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_communication_log"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#333333" />

                <Button
                    android:id="@+id/btnClearLockerLog"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="@string/auto_clear_log"
                    android:background="#795548"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:minWidth="70dp" />
            </LinearLayout>

            <!-- Communication Log -->
            <ScrollView
                android:id="@+id/scrollLockerLog"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="#263238"
                android:padding="2dp">

                <TextView
                    android:id="@+id/tvLockerLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:padding="6dp"
                    android:text="@string/auto_log"
                    android:textColor="#4FC3F7"
                    android:textSize="9sp" />
            </ScrollView>
        </LinearLayout>

        <!-- ===== BARCODE SCANNER SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="3dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_honeywell_xenon_1900_barcode_s"
                android:textStyle="bold"
                android:textSize="26sp"
                android:textColor="#1976D2"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_15_pin_sub_d_to_rs232_connecti"
                android:textSize="16sp"
                android:textColor="#666666"
                android:layout_marginBottom="12dp" />

            <!-- Scanner Status -->
            <TextView
                android:id="@+id/tvScannerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_scanner_status_initializing"
                android:textSize="16sp"
                android:background="#FFF8E1"
                android:padding="8dp"
                android:layout_marginBottom="8dp" />

            <!-- Scanner Control Buttons -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnScannerFocus"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_focus_input"
                    android:background="#FF9800"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnTriggerScan"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_trigger_scan"
                    android:background="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:enabled="false" />
            </LinearLayout>

            <!-- Scanner Utility Buttons -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnClearScans"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_clear_results"
                    android:background="#9E9E9E"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnScannerReconnect"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_reconnect"
                    android:background="#2196F3"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Scanner Instructions -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_instructions_press_trigger_sca"
                android:textSize="15sp"
                android:textColor="#757575"
                android:background="#F5F5F5"
                android:padding="8dp"
                android:layout_marginBottom="8dp" />

            <!-- Scanned Results Display -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_scanned_results"
                android:textStyle="bold"
                android:textSize="20sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etScannerResults"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="top"
                android:hint="@string/auto_scanned_barcodes_will_appear_h"
                android:inputType="textMultiLine"
                android:background="#F8F8F8"
                android:padding="12dp"
                android:textSize="15sp"
                android:scrollbars="vertical"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <!-- Scanner Connection Info -->
            <TextView
                android:id="@+id/tvScannerInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_connection_info_will_appear_he"
                android:textSize="14sp"
                android:textColor="#9E9E9E"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ===== THERMAL PRINTER SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="3dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_custom_tg2480hiii_thermal_prin"
                android:textStyle="bold"
                android:textSize="26sp"
                android:textColor="#1976D2"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_usb_connection_using_custom_sp"
                android:textSize="16sp"
                android:textColor="#666666"
                android:layout_marginBottom="12dp" />

            <!-- Printer Status -->
            <TextView
                android:id="@+id/tvPrinterStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_printer_status_initializing"
                android:textSize="16sp"
                android:background="#E3F2FD"
                android:padding="8dp"
                android:layout_marginBottom="8dp" />

            <!-- Printer Details -->
            <TextView
                android:id="@+id/tvPrinterDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_ready_paper_connection"
                android:textSize="15sp"
                android:padding="6dp"
                android:background="#FAFAFA"
                android:layout_marginBottom="12dp" />

            <!-- Basic Print Test Buttons -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnPrintTest"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_print_test_page"
                    android:background="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnPrinterStatus"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_check_status"
                    android:background="#2196F3"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Advanced Print Test Buttons -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnPrintReceipt"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_print_receipt"
                    android:background="#FF9800"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnPrintBarcode"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_print_barcodes"
                    android:background="#9C27B0"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ===== COMPREHENSIVE TESTING SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="3dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_comprehensive_testing"
                android:textStyle="bold"
                android:textSize="26sp"
                android:textColor="#1976D2"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnRunAllTests"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_run_all_tests"
                    android:background="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:textSize="22sp"
                    android:padding="12dp" />

                <Button
                    android:id="@+id/btnResetAll"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_reset_all"
                    android:background="#FF5722"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="8dp"
                    android:textSize="22sp"
                    android:padding="12dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ===== SYSTEM INFO SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="3dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_system_information"
                android:textStyle="bold"
                android:textSize="26sp"
                android:textColor="#1976D2"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_hardware_platform_rockchip_rk3"
                android:textSize="15sp"
                android:padding="12dp"
                android:background="#F8F8F8"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Footer spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>